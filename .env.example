# Social Cues local server environment
# Copy this file to `.env` in the same folder and fill in the secret values.
# Never paste service-role keys into browser files or chat.

PORT=4177
HOST=0.0.0.0
BRAND_DOMAIN=socialcuesapp.com
BRAND_HOME_URL=https://socialcuesapp.com
SUPPORT_EMAIL=mr.barton@socialcuesapp.com
AUTH_PROVIDER=supabase
AUTH_SESSION_SECRET=
SOCIAL_CUES_ADMIN_EMAILS=
SOCIAL_CUES_PUBLIC_SIGNUP_ENABLED=false
# Comma-separated SHA-256 hashes of normalized promo codes. Never store plaintext codes here.
SOCIAL_CUES_PROMO_CODE_HASHES=

# Sentry error tracking (optional until the Sentry project exists)
# DSN is safe for browser use; never put SENTRY_AUTH_TOKEN in browser code.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_DIST=
SENTRY_GITHUB_REPOSITORY=NovaForgeShop/social-cues-app
SENTRY_SOURCE_CONTEXT_ENABLED=true
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_BROWSER_CDN_URL=https://browser.sentry-cdn.com/10.66.0/bundle.min.js

# Supabase Auth custom SMTP
# These also need to be saved into Supabase Auth settings; app env alone is only
# used for readiness checks and operational visibility.
SUPABASE_ACCESS_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=mr.barton@socialcuesapp.com
SMTP_SENDER_NAME=Social Cues
SUPABASE_SMTP_APPLIED=false

# Resend
# Resend can supply Supabase custom SMTP:
# host=smtp.resend.com, port=587, user=resend, pass=RESEND_API_KEY
RESEND_API_KEY=

SUPABASE_URL=https://arbkgucejiovqakwvibw.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ENABLED=true

# Future production integrations
OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_VIDEO_MODEL=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FOUNDER_AUDIT=
STRIPE_PRICE_CAMPAIGN_BUILD=
STRIPE_PRICE_PRO_MONTHLY=
PUBLISHING_QUEUE_MODE=social-cues

# Discord
# Add this callback URL in the Discord Developer Portal OAuth2 settings:
# https://socialcuesapp.com/api/oauth/discord/callback
DISCORD_PUBLIC_APP_URL=https://socialcuesapp.com
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ANNOUNCEMENT_CHANNEL_ID=

# AI editor pipeline
MEDIA_EDITOR_PROVIDER=openai
MEDIA_STORAGE_PROVIDER=supabase-storage
MEDIA_STORAGE_BUCKET=social-cues-media
MEDIA_MAX_UPLOAD_MB=250
MEDIA_CAMERA_CAPTURE_ENABLED=true
MEDIA_MIC_CAPTURE_ENABLED=true
VERCEL_BLOB_READ_WRITE_TOKEN=
MAX_JSON_BODY_BYTES=1048576

# Meta / Facebook / Instagram
# Hosted OAuth callbacks use the production Social Cues domain.
PUBLIC_APP_URL=https://socialcuesapp.com
META_PUBLIC_APP_URL=https://socialcuesapp.com
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v25.0
OAUTH_TOKEN_ENCRYPTION_KEY=
WEBHOOK_VERIFY_TOKEN=
WEBHOOK_SIGNING_SECRET=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# X / Twitter
# Add this exact callback URL in X user authentication settings, replacing the host if needed:
# http://127.0.0.1:4177/api/oauth/x/callback
X_PUBLIC_APP_URL=http://127.0.0.1:4177
X_CLIENT_ID=
X_CLIENT_SECRET=

# TikTok
# Add this callback URL in TikTok Login Kit:
# https://socialcuesapp.com/api/oauth/tiktok/callback
TIKTOK_PUBLIC_APP_URL=https://socialcuesapp.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Use sandbox mode before TikTok production review is Live.
# Sandbox also requires adding the logging-in TikTok account as a target user in TikTok for Developers.
TIKTOK_OAUTH_MODE=sandbox
TIKTOK_SANDBOX_PUBLIC_APP_URL=https://socialcuesapp.com
TIKTOK_SANDBOX_CLIENT_KEY=
TIKTOK_SANDBOX_CLIENT_SECRET=
# Keep first OAuth minimal until TikTok approves Display/Content Posting scopes.
TIKTOK_OAUTH_SCOPES=user.info.basic
TIKTOK_DISABLE_AUTO_AUTH=1

# Pinterest
# Add this callback URL in Pinterest Developers:
# https://socialcuesapp.com/api/oauth/pinterest/callback
PINTEREST_PUBLIC_APP_URL=https://socialcuesapp.com
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Canva Connect
# Use Canva Developer Portal > Your integrations for these OAuth credentials.
# The Canva Apps SDK app id is separate and does not replace CANVA_CLIENT_ID.
# Add this callback URL in the Canva Connect integration:
# https://socialcuesapp.com/api/oauth/canva/callback
CANVA_PUBLIC_APP_URL=https://socialcuesapp.com
CANVA_APP_ID=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Shopify
# Add this callback URL in Shopify Partners:
# https://socialcuesapp.com/api/oauth/shopify/callback
SHOPIFY_PUBLIC_APP_URL=https://socialcuesapp.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SHOP_DOMAIN=

# Etsy
# Add this callback URL in Etsy Developers:
# https://socialcuesapp.com/api/oauth/etsy/callback
ETSY_PUBLIC_APP_URL=https://socialcuesapp.com
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=

# LinkedIn - approval-gated backlog
# Do not prioritize until the app/product is approved and brand/IP footing is settled.
# Future redirect URL in the LinkedIn Developer app Auth tab:
# https://socialcuesapp.com/api/oauth/linkedin/callback
LINKEDIN_PUBLIC_APP_URL=https://socialcuesapp.com
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitch
# Add this OAuth redirect URL in Twitch Developers:
# https://socialcuesapp.com/api/oauth/twitch/callback
TWITCH_PUBLIC_APP_URL=https://socialcuesapp.com
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Google / YouTube
# Add this callback URL in the Google OAuth web client:
# https://socialcuesapp.com/api/oauth/youtube/callback
GOOGLE_PUBLIC_APP_URL=https://socialcuesapp.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=UC-hAyPwzwXBGTyK7nsmfcJA
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://socialcuesapp.com
GOOGLE_ANALYTICS_PROPERTY_ID=
