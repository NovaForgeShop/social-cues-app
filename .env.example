# Social Cues local server environment
# Copy this file to `.env` in the same folder and fill in the secret values.
# Never paste service-role keys into browser files or chat.

PORT=4177
HOST=0.0.0.0
BRAND_DOMAIN=socialcuesapp.com
BRAND_HOME_URL=https://socialcuesapp.com
SUPPORT_EMAIL=mr.barton@socialcuesapp.com

SUPABASE_URL=https://arbkgucejiovqakwvibw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ENABLED=true

# Future production integrations
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLISHING_QUEUE_MODE=social-cues

# Meta / Facebook / Instagram
# Threads OAuth requires an HTTPS PUBLIC_APP_URL.
PUBLIC_APP_URL=http://127.0.0.1:4177
META_PUBLIC_APP_URL=https://arbkgucejiovqakwvibw.supabase.co/functions/v1/meta-oauth-callback
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v23.0
OAUTH_TOKEN_ENCRYPTION_KEY=
WEBHOOK_VERIFY_TOKEN=
WEBHOOK_SIGNING_SECRET=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# X / Twitter
# Add this exact callback URL in X user authentication settings, replacing the host if needed:
# http://127.0.0.1:4177/api/oauth/x/callback
X_PUBLIC_APP_URL=http://127.0.0.1:4177
X_CLIENT_ID=
X_CLIENT_SECRET=
