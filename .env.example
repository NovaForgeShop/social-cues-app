# Social Cues local server environment
# Copy this file to `.env` in the same folder and fill in the secret values.
# Never paste service-role keys into browser files or chat.

PORT=4177
HOST=0.0.0.0
BRAND_DOMAIN=socialcuesapp.com
BRAND_HOME_URL=https://socialcuesapp.com
SUPPORT_EMAIL=mr.barton@socialcuesapp.com
ACCOUNT_SIGNUP_OWNER_EMAILS=mr.barton@socialcuesapp.com,barton.cory.m@gmail.com
AUTH_PROVIDER=supabase
AUTH_SESSION_SECRET=
# JSON array of invite-only tester codes. Store the real value in Vercel as a
# Sensitive production variable; never place active codes in source control.
SOCIAL_CUES_PROMO_CODES=
REDDIT_DEVVIT_PROJECT_READY=false
REDDIT_DEVVIT_COMMUNITY_COMMAND_READY=false

# Supabase Auth custom SMTP
# These also need to be saved into Supabase Auth settings; app env alone is only
# used for readiness checks and operational visibility.
SUPABASE_ACCESS_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=mr.barton@socialcuesapp.com
SMTP_SENDER_NAME=Social Cues
SUPABASE_SMTP_APPLIED=false

# Resend
# Resend can supply Supabase custom SMTP:
# host=smtp.resend.com, port=587, user=resend, pass=RESEND_API_KEY
RESEND_API_KEY=

SUPABASE_URL=https://arbkgucejiovqakwvibw.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ENABLED=true

# Durable workers
# Vercel Cron sends CRON_SECRET as a Bearer token. WORKER_SECRET may be the
# same value, but keeping a separate value allows future non-cron workers.
CRON_SECRET=
WORKER_SECRET=
WORKER_BATCH_SIZE=8
WORKER_LEASE_SECONDS=240
WORKER_TIME_BUDGET_MS=240000
# Global ceiling. Each provider also has a shorter safe renewal window so a
# newly issued short-lived token is not refreshed again on every cron tick.
TOKEN_REFRESH_LEAD_MINUTES=1440
# Keep disabled until the production queue has been audited and a controlled
# scheduled post has passed end to end. Token renewal and notifications still run.
AUTOMATIC_PUBLISHING_ENABLED=false
# Do not send stale email accumulated before the worker was activated.
NOTIFICATION_EMAIL_MAX_AGE_HOURS=24
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:mr.barton@socialcuesapp.com

# Set true only after the isolated Cloud Run Job and its one-minute Cloud
# Scheduler trigger are deployed and have passed a real private-media render.
MEDIA_RENDER_WORKER_CONFIGURED=false

# Future production integrations
OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_VIDEO_MODEL=
OPENAI_DAILY_REQUEST_LIMIT=40
OPENAI_MONTHLY_REQUEST_LIMIT=500
OPENAI_MONTHLY_TOKEN_LIMIT=1500000
# Set these to the selected model's current rates before displaying currency.
# Keep them at zero when only request and token metering should be reported.
OPENAI_INPUT_COST_PER_MILLION_MICROUSD=0
OPENAI_OUTPUT_COST_PER_MILLION_MICROUSD=0
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FOUNDER_AUDIT=
STRIPE_PRICE_CAMPAIGN_BUILD=
STRIPE_PRICE_PRO_MONTHLY=
PUBLISHING_QUEUE_MODE=social-cues

# Discord
# Add this callback URL in the Discord Developer Portal OAuth2 settings:
# https://socialcuesapp.com/api/oauth/discord/callback
# Add this signed Webhook Events URL and subscribe to APPLICATION_AUTHORIZED and APPLICATION_DEAUTHORIZED:
# https://socialcuesapp.com/api/discord/webhook-events
# Guild Install defaults: scopes bot + applications.commands; permissions integer 126016.
DISCORD_PUBLIC_APP_URL=https://socialcuesapp.com
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ANNOUNCEMENT_CHANNEL_ID=

# AI editor pipeline
MEDIA_EDITOR_PROVIDER=openai
MEDIA_STORAGE_PROVIDER=supabase-storage
MEDIA_STORAGE_BUCKET=social-cues-media
MEDIA_MAX_UPLOAD_MB=250
MEDIA_CAMERA_CAPTURE_ENABLED=true
MEDIA_MIC_CAPTURE_ENABLED=true
VERCEL_BLOB_READ_WRITE_TOKEN=
MAX_JSON_BODY_BYTES=1048576

# Meta / Facebook / Instagram
# Hosted OAuth callbacks use the production Social Cues domain.
PUBLIC_APP_URL=https://socialcuesapp.com
META_PUBLIC_APP_URL=https://socialcuesapp.com
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v25.0
INSTAGRAM_PUBLIC_APP_URL=https://socialcuesapp.com
# Instagram API with Instagram Login callback:
# https://socialcuesapp.com/api/oauth/instagram/callback
# Copy these from Instagram > API setup with Instagram Login.
# Do not rely on META_APP_ID fallback; Instagram OAuth can reject that as "Invalid platform app".
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_API_VERSION=v25.0
OAUTH_TOKEN_ENCRYPTION_KEY=
WEBHOOK_VERIFY_TOKEN=
WEBHOOK_SIGNING_SECRET=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# X / Twitter
# Add this exact callback URL in X user authentication settings, replacing the host if needed:
# https://socialcuesapp.com/api/oauth/x/callback
X_PUBLIC_APP_URL=https://socialcuesapp.com
X_CLIENT_ID=
X_CLIENT_SECRET=
# Read-first login avoids X invalid_request failures when write permissions are not ready.
X_OAUTH_SCOPES=tweet.read users.read offline.access
X_OAUTH_WRITE_SCOPES=tweet.read tweet.write users.read offline.access

# TikTok
# Add this callback URL in TikTok Login Kit:
# https://socialcuesapp.com/api/oauth/tiktok/callback
TIKTOK_PUBLIC_APP_URL=https://socialcuesapp.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Use sandbox mode before TikTok production review is Live.
# Sandbox also requires adding the logging-in TikTok account as a target user in TikTok for Developers.
TIKTOK_OAUTH_MODE=sandbox
TIKTOK_SANDBOX_PUBLIC_APP_URL=https://socialcuesapp.com
TIKTOK_SANDBOX_CLIENT_KEY=
TIKTOK_SANDBOX_CLIENT_SECRET=
# Keep first OAuth minimal until TikTok approves Display/Content Posting scopes.
TIKTOK_OAUTH_SCOPES=user.info.basic
TIKTOK_DISABLE_AUTO_AUTH=1

# Pinterest
# Add this callback URL in Pinterest Developers:
# https://socialcuesapp.com/api/oauth/pinterest/callback
PINTEREST_PUBLIC_APP_URL=https://socialcuesapp.com
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_ACCESS_TIER=

# Canva Connect
# Use Canva Developer Portal > Your integrations for these OAuth credentials.
# The Canva Apps SDK app id is separate and does not replace CANVA_CLIENT_ID.
# Add this callback URL in the Canva Connect integration:
# https://socialcuesapp.com/api/oauth/canva/callback
CANVA_PUBLIC_APP_URL=https://socialcuesapp.com
CANVA_APP_ID=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Shopify
# Add this callback URL in Shopify Partners:
# https://socialcuesapp.com/api/oauth/shopify/callback
SHOPIFY_PUBLIC_APP_URL=https://socialcuesapp.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SHOP_DOMAIN=

# Etsy
# Add this callback URL in Etsy Developers:
# https://socialcuesapp.com/api/oauth/etsy/callback
ETSY_PUBLIC_APP_URL=https://socialcuesapp.com
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=

# LinkedIn
# Social Cues App id 247552113. Privacy URL and callback are saved in the portal.
# Request Sign In with LinkedIn using OpenID Connect for member login first.
# Community Management and Company Page features remain a separate Product/tier.
# Add only scopes LinkedIn actually grants; an empty value intentionally blocks OAuth.
# https://socialcuesapp.com/api/oauth/linkedin/callback
LINKEDIN_PUBLIC_APP_URL=https://socialcuesapp.com
LINKEDIN_APPLICATION_ID=247552113
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202606
LINKEDIN_OIDC_PRODUCT_GRANTED=false
LINKEDIN_COMPANY_VERIFIED=false
LINKEDIN_COMMUNITY_MANAGEMENT_TIER=not-requested
LINKEDIN_OAUTH_SCOPES=
# Standard tier only. LinkedIn validates this endpoint with challengeCode/HMAC.
# https://socialcuesapp.com/api/linkedin/webhook

# Patreon API v2
# Callback: https://socialcuesapp.com/api/oauth/patreon/callback
# Email and mailing-address scopes are intentionally omitted.
PATREON_PUBLIC_APP_URL=https://socialcuesapp.com
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_OAUTH_SCOPES=identity campaigns campaigns.members campaigns.posts w:campaigns.webhook
# Add only after Patreon creates a webhook and returns its signing secret.
PATREON_WEBHOOK_SECRET=

# Twitch
# Add this OAuth redirect URL in Twitch Developers:
# https://socialcuesapp.com/api/oauth/twitch/callback
TWITCH_PUBLIC_APP_URL=https://socialcuesapp.com
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Manychat
# Optional server fallback only. Customer keys are entered in Accounts and encrypted per workspace.
# Long term, use the Manychat Developer Program App Key issued uniquely per installation.
MANYCHAT_ACCOUNT_API_KEY=
# Separate operator/profile-scoped key; only used for template installation links.
MANYCHAT_PROFILE_API_KEY=
MANYCHAT_DAILY_REQUEST_LIMIT=1000
MANYCHAT_DAILY_SEND_LIMIT=50
MANYCHAT_SUBSCRIBER_HOURLY_SEND_LIMIT=5

# ElevenLabs
# Primary customer model: users create a restricted key with a credit quota,
# then connect it from Accounts. Never store an ElevenLabs login or password.
# Optional server fallback for an internal Social Cues-owned workspace only.
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_DAILY_REQUEST_LIMIT=100
ELEVENLABS_DAILY_CHARACTER_LIMIT=10000
ELEVENLABS_MAX_TEXT_CHARACTERS=2500

# Google / YouTube
# Add this callback URL in the Google OAuth web client:
# https://socialcuesapp.com/api/oauth/youtube/callback
GOOGLE_PUBLIC_APP_URL=https://socialcuesapp.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=UC-hAyPwzwXBGTyK7nsmfcJA
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_BUSINESS_ACCOUNT_ID=
GOOGLE_BUSINESS_LOCATION_ID=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://socialcuesapp.com
GOOGLE_ANALYTICS_PROPERTY_ID=

# Reddit / Devvit
# Devvit setup starts at https://developers.reddit.com/new and produces a
# one-time npm create command. Reddit commercial/data use and Ads API access
# are separate approval gates for a monetized Social Cues product.
REDDIT_PUBLIC_APP_URL=https://socialcuesapp.com
REDDIT_DEVVIT_APP_SLUG=social-cues-app
REDDIT_DEVVIT_PLAYTEST_SUBREDDIT=social_cues_app_dev
REDDIT_COMMERCIAL_APPROVED=false
REDDIT_DATA_API_CLIENT_ID=
REDDIT_DATA_API_CLIENT_SECRET=
REDDIT_ADS_API_CLIENT_ID=
REDDIT_ADS_API_CLIENT_SECRET=
REDDIT_ADS_ACCOUNT_ID=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_LOGS_ENABLED=true
